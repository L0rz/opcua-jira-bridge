# ============================================================
# Jira Zugangsdaten (PFLICHT)
# ============================================================
JIRA_URL=https://your-jira.atlassian.net
JIRA_USER=your@email.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECT_KEY=RKS
JIRA_ACCOUNT_ID=your-account-id

# ============================================================
# OPC UA Server (OPTIONAL — überschreibt opcua_config.yaml)
# ============================================================
# Endpoint des OPC UA Servers
OPCUA_ENDPOINT=opc.tcp://localhost:4840/freeopcua/server/

# Nur bei auth_mode: username (überschreibt config)
OPCUA_USERNAME=
OPCUA_PASSWORD=

# ============================================================
# API Server
# ============================================================
API_HOST=0.0.0.0
API_PORT=8080
